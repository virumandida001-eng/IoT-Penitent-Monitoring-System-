<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>MedSentry needs continuous Bluetooth access to stream real-time vitals from your paired ESP32 wearable sensor device.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>MedSentry needs Bluetooth access to pair and communicate with your wearable sensor device.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>MedSentry tracks your background location to send precise coordinates to emergency contacts and emergency services when you trigger the SOS alarm.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>MedSentry uses your location to attach current coordinates during an emergency SOS transmission.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>MedSentry uses Face ID to provide quick and secure biometric access to your dashboard and medical records.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
